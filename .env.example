# Copy this file to ".env" and paste your key(s) below.
# ".env" is git-ignored, so it is never committed or pushed to GitHub.
# The analyzer loads ".env" automatically on every run.

# Free option - Google Gemini (get a free key: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-key-here

# Paid option - Claude (highest accuracy: https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# Other free/OpenAI-compatible providers (optional)
# GROQ_API_KEY=...
# OPENROUTER_API_KEY=...
